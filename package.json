{
	"name": "companion-module-hopla-powerstudio",
	"version": "1.0.2",
	"description": "Bitfocus Companion module for controlling Power Studio through its REST API.",
	"main": "dist/main.js",
	"type": "module",
	"packageManager": "yarn@4.12.0",
	"scripts": {
		"format": "prettier -w .",
		"prepare": "husky",
		"package": "yarn clean && yarn build && companion-module-build",
		"clean": "rimraf dist",
		"build": "yarn build:main",
		"build:main": "tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch",
		"test": "tsc -p tsconfig.test.json && node .test-dist/tests/run-tests.js",
		"lint:raw": "eslint",
		"lint": "yarn lint:raw ."
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bitfocus/companion-module-hopla-powerstudio.git"
	},
	"engines": {
		"node": "^22.20"
	},
	"dependencies": {
		"@companion-module/base": "2.0.4"
	},
	"devDependencies": {
		"@companion-module/tools": "^3.0.1",
		"@types/node": "^22.19.17",
		"eslint": "^9.39.4",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.3",
		"rimraf": "^6.1.3",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.59.0"
	},
	"prettier": "@companion-module/tools/.prettierrc.json",
	"lint-staged": {
		"*.{css,json,md,scss}": [
			"prettier --write"
		],
		"*.{ts,tsx,js,jsx}": [
			"yarn lint:raw --fix"
		]
	}
}
